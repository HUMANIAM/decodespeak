{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "behavior",
    "risks"
  ],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "behavior": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
